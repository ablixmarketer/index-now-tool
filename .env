# IndexNow Configuration
# Generate your key from: https://www.indexnow.org/
INDEXNOW_KEY=
INDEXNOW_KEY_LOCATION=

# Bing Submission API Configuration
# Get your Bing API key from: https://www.bing.com/webmasters/
